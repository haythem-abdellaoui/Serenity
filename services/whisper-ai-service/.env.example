# Local-only environment variables for whisper-ai-service
#
# Copy this file to .env and fill values locally.
# .env is gitignored; keep secrets there only.

# --- Server / runtime ---
WHISPER_HOST=0.0.0.0
WHISPER_PORT=5002

# --- Whisper model/runtime ---
WHISPER_MODEL_DIR=models/faster-whisper-tiny
WHISPER_MODEL_NAME=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=8
WHISPER_BEST_OF=5
WHISPER_TEMPERATURE=0.0
WHISPER_VAD_FILTER=true
WHISPER_INITIAL_PROMPT=

# --- Lara Translate (https://laratranslate.com) ---
LARA_ACCESS_KEY_ID=
LARA_ACCESS_KEY_SECRET=
